ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# Google Cloud Text-to-Speech.
# Used locally by `npm run audio:google` to pre-generate clips, and at runtime by
# the server's /api/tts fallback. Enable the "Cloud Text-to-Speech API" in a
# Google Cloud project and create an API key.
#  - Local clip generation: put the key in .env.local (this file's .local copy).
#  - Production (Azure): set GOOGLE_TTS_API_KEY as an App Service application setting.
GOOGLE_TTS_API_KEY=
# Optional generation tuning (Google valid ranges: speakingRate 0.25–2.0, pitch -20–20):
GOOGLE_TTS_SPEAKING_RATE=1
GOOGLE_TTS_PITCH=0
